{
  "name": "app-blueprint",
  "version": "0.1.12",
  "description": "Cross-platform desktop UI app with Electron and TypeScript",
  "main": "dist/main.js",
  "author": "Stephan Praetsch <noreply@example.com>",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=26.x"
  },
  "scripts": {
    "build": "tsc",
    "dev": "yarn build && electron .",
    "start": "electron .",
    "dist": "yarn build && electron-builder --publish=never",
    "dist:linux": "yarn build && electron-builder --linux AppImage deb --publish=never",
    "dist:linux:appimage": "yarn build && electron-builder --linux AppImage --publish=never",
    "dist:win": "yarn build && electron-builder --win nsis --publish=never",
    "dist:mac": "yarn build && electron-builder --mac dmg --publish=never"
  },
  "devDependencies": {
    "@types/node": "24.13.2",
    "electron": "43.0.0",
    "electron-builder": "26.15.3",
    "typescript": "5.9.3"
  },
  "build": {
    "appId": "com.example.appblueprint",
    "productName": "App Blueprint",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "index.html",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "packageManager": "yarn@1.22.22"
}
